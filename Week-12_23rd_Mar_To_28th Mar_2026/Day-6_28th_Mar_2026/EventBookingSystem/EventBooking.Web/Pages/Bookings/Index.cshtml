@page
@model EventBooking.Web.Pages.Bookings.IndexModel
@{ ViewData["Title"] = "My Bookings"; }

<div class="container py-2">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h2 class="fw-bold mb-1">My Bookings</h2>
      <p class="text-muted mb-0">Track and manage your event tickets</p>
    </div>
    <a href="/Events" class="btn btn-primary rounded-pill">
      <i class="bi bi-plus-circle me-1"></i>Book More
    </a>
  </div>

  <div id="loadingState" class="text-center py-5">
    <div class="spinner-border text-primary" role="status"></div>
  </div>

  <div id="emptyState" class="text-center py-5 d-none">
    <i class="bi bi-calendar-x display-3 text-muted"></i>
    <h5 class="mt-3 text-muted">No bookings yet</h5>
    <a href="/Events" class="btn btn-primary rounded-pill mt-2">Browse Events</a>
  </div>

  <div id="bookingsContainer" class="d-none">
    <!-- Stats row -->
    <div class="row g-3 mb-4" id="statsRow"></div>

    <!-- Bookings table -->
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-4">Event</th>
                <th>Date</th>
                <th>Location</th>
                <th>Seats</th>
                <th>Amount</th>
                <th>Status</th>
                <th class="pe-4">Action</th>
              </tr>
            </thead>
            <tbody id="bookingsBody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Cancel Confirmation Modal -->
<div class="modal fade" id="cancelModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content border-0 rounded-4 text-center p-2">
      <div class="modal-body py-4">
        <i class="bi bi-exclamation-triangle-fill text-warning fs-1 mb-3 d-block"></i>
        <h5 class="fw-bold">Cancel Booking?</h5>
        <p class="text-muted small">This will release your seats. This action cannot be undone.</p>
      </div>
      <div class="modal-footer border-0 justify-content-center pb-4 gap-2">
        <button class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Keep it</button>
        <button class="btn btn-danger rounded-pill px-4" id="confirmCancelBtn">Yes, Cancel</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
let bookings = [];
let cancelId = null;

async function loadBookings() {
  if (!isLoggedIn()) { window.location.href = '/Auth/Login'; return; }

  try {
    const resp = await apiFetch('/api/bookings');
    bookings = await resp.json();
    renderBookings(bookings);
  } catch (err) {
    document.getElementById('loadingState').innerHTML =
      `<div class="alert alert-danger">Failed to load bookings: ${err.message}</div>`;
  }
}

function renderBookings(data) {
  document.getElementById('loadingState').classList.add('d-none');

  if (data.length === 0) {
    document.getElementById('emptyState').classList.remove('d-none');
    return;
  }

  document.getElementById('bookingsContainer').classList.remove('d-none');

  // Stats
  const totalSeats = data.reduce((s, b) => s + b.seatsBooked, 0);
  document.getElementById('statsRow').innerHTML = `
    <div class="col-sm-4">
      <div class="card border-0 bg-primary bg-opacity-10 rounded-4 text-center p-3">
        <div class="fs-2 fw-bold text-primary">${data.length}</div>
        <div class="text-muted small">Active Bookings</div>
      </div>
    </div>
    <div class="col-sm-4">
      <div class="card border-0 bg-success bg-opacity-10 rounded-4 text-center p-3">
        <div class="fs-2 fw-bold text-success">${totalSeats}</div>
        <div class="text-muted small">Total Seats</div>
      </div>
    </div>
    <div class="col-sm-4">
      <div class="card border-0 bg-warning bg-opacity-10 rounded-4 text-center p-3">
        <div class="fs-2 fw-bold text-warning">${data.filter(b => new Date(b.eventDate) > new Date()).length}</div>
        <div class="text-muted small">Upcoming</div>
      </div>
    </div>`;

  document.getElementById('bookingsBody').innerHTML = data.map(b => {
    const date = new Date(b.eventDate).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' });
    const isPast = new Date(b.eventDate) < new Date();
    return `
      <tr class="booking-row">
        <td class="ps-4 py-3">
          <div class="fw-semibold">${b.eventTitle}</div>
          <div class="text-muted small">Booked ${new Date(b.bookedAt).toLocaleDateString('en-IN')}</div>
        </td>
        <td class="py-3 small">${date}</td>
        <td class="py-3 small text-muted">${b.eventLocation}</td>
        <td class="py-3"><span class="badge bg-primary rounded-pill">${b.seatsBooked}</span></td>
        <td class="py-3 fw-semibold text-primary">–</td>
        <td class="py-3">
          <span class="badge rounded-pill ${isPast ? 'bg-secondary' : 'bg-success'} bg-opacity-75">
            ${isPast ? 'Past' : b.status}
          </span>
        </td>
        <td class="pe-4 py-3">
          ${!isPast ? `<button class="btn btn-sm btn-outline-danger rounded-pill" onclick="openCancel(${b.id})">
            <i class="bi bi-x-circle me-1"></i>Cancel
          </button>` : '<span class="text-muted small">—</span>'}
        </td>
      </tr>`;
  }).join('');
}

function openCancel(id) {
  cancelId = id;
  const modal = new bootstrap.Modal(document.getElementById('cancelModal'));
  modal.show();
}

document.getElementById('confirmCancelBtn').addEventListener('click', async () => {
  const btn = document.getElementById('confirmCancelBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

  try {
    const resp = await apiFetch(`/api/bookings/${cancelId}`, { method: 'DELETE' });
    if (resp.ok) {
      bootstrap.Modal.getInstance(document.getElementById('cancelModal')).hide();
      showToast('Booking cancelled successfully.', 'success');
      loadBookings();
    } else {
      showToast('Failed to cancel booking.', 'danger');
    }
  } catch (e) {
    showToast(e.message, 'danger');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Yes, Cancel';
  }
});

loadBookings();
</script>
}