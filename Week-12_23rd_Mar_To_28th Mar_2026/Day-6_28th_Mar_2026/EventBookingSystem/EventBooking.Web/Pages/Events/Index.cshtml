@page
@model EventBooking.Web.Pages.Events.IndexModel
@{ ViewData["Title"] = "Browse Events"; }

<!-- Hero -->
<section class="hero-section">
  <div class="container text-center">
    <h1 class="display-5 fw-bold mb-3">Discover Amazing Events</h1>
    <p class="lead mb-4 opacity-75">Find concerts, conferences, and experiences near you</p>
    <div class="input-group mx-auto" style="max-width:480px">
      <span class="input-group-text bg-white border-0 pe-1">
        <i class="bi bi-search text-muted"></i>
      </span>
      <input type="text" id="searchInput" class="form-control border-0 shadow-none"
             placeholder="Search events, locations..." oninput="filterEvents()">
    </div>
  </div>
</section>

<div class="container mt-4">
  <!-- Category filter -->
  <div class="filter-bar d-flex flex-wrap gap-2 mb-4">
    <input type="radio" class="btn-check" name="category" id="catAll" value="" checked onchange="filterEvents()">
    <label class="btn btn-sm btn-outline-secondary rounded-pill px-3" for="catAll">All</label>

    <input type="radio" class="btn-check" name="category" id="catTech" value="Technology" onchange="filterEvents()">
    <label class="btn btn-sm btn-outline-secondary rounded-pill px-3" for="catTech">
      <i class="bi bi-cpu me-1"></i>Technology
    </label>

    <input type="radio" class="btn-check" name="category" id="catMusic" value="Music" onchange="filterEvents()">
    <label class="btn btn-sm btn-outline-secondary rounded-pill px-3" for="catMusic">
      <i class="bi bi-music-note me-1"></i>Music
    </label>

    <input type="radio" class="btn-check" name="category" id="catBiz" value="Business" onchange="filterEvents()">
    <label class="btn btn-sm btn-outline-secondary rounded-pill px-3" for="catBiz">
      <i class="bi bi-briefcase me-1"></i>Business
    </label>

    <input type="radio" class="btn-check" name="category" id="catSports" value="Sports" onchange="filterEvents()">
    <label class="btn btn-sm btn-outline-secondary rounded-pill px-3" for="catSports">
      <i class="bi bi-trophy me-1"></i>Sports
    </label>
  </div>

  <!-- Loading / Error states -->
  <div id="loadingState" class="text-center py-5">
    <div class="spinner-border text-primary" role="status"></div>
    <p class="mt-2 text-muted">Loading events...</p>
  </div>
  <div id="errorState" class="alert alert-danger d-none" role="alert"></div>
  <div id="emptyState" class="text-center py-5 d-none">
    <i class="bi bi-calendar-x display-4 text-muted"></i>
    <p class="mt-3 text-muted">No events found matching your search.</p>
  </div>

  <!-- Events grid -->
  <div id="eventsGrid" class="row g-4 d-none"></div>
</div>

<!-- Booking Modal -->
<div class="modal fade" id="bookingModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold" id="modalEventTitle">Book Tickets</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="event-summary p-3 bg-light rounded-3 mb-3">
          <div class="row g-2 small text-muted">
            <div class="col-6"><i class="bi bi-geo-alt me-1"></i><span id="modalLocation"></span></div>
            <div class="col-6"><i class="bi bi-calendar me-1"></i><span id="modalDate"></span></div>
            <div class="col-6"><i class="bi bi-ticket me-1"></i>₹<span id="modalPrice"></span>/seat</div>
            <div class="col-6"><i class="bi bi-people me-1"></i><span id="modalSeats"></span> seats left</div>
          </div>
        </div>

        <div id="bookingError" class="alert alert-danger d-none"></div>
        <div id="bookingSuccess" class="alert alert-success d-none"></div>

        <div id="bookingForm">
          <label class="form-label fw-semibold">Number of Seats</label>
          <input type="number" id="seatsInput" class="form-control form-control-lg text-center"
                 min="1" max="50" value="1" oninput="updateTotal()">
          <div id="seatsError" class="invalid-feedback"></div>

          <div class="d-flex justify-content-between align-items-center mt-3 p-3 bg-primary bg-opacity-10 rounded-3">
            <span class="text-muted">Total Amount</span>
            <span class="fs-4 fw-bold text-primary">₹<span id="totalAmount">0</span></span>
          </div>
        </div>
      </div>
      <div class="modal-footer border-0 pt-0" id="bookingFooter">
        <button class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary rounded-pill px-4" id="confirmBookBtn" onclick="submitBooking()">
          <i class="bi bi-check2-circle me-1"></i>Confirm Booking
        </button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
let allEvents = [];
let currentEvent = null;

// ── Fetch events from API ──────────────────────────────────────────────
async function loadEvents() {
  try {
    const resp = await apiFetch('/api/events');
    allEvents = await resp.json();
    renderEvents(allEvents);
  } catch (err) {
    document.getElementById('loadingState').classList.add('d-none');
    const errEl = document.getElementById('errorState');
    errEl.textContent = 'Failed to load events. Make sure the API is running.';
    errEl.classList.remove('d-none');
  }
}

// ── Render event cards ─────────────────────────────────────────────────
function renderEvents(events) {
  document.getElementById('loadingState').classList.add('d-none');
  const grid = document.getElementById('eventsGrid');
  const empty = document.getElementById('emptyState');

  if (events.length === 0) {
    grid.classList.add('d-none');
    empty.classList.remove('d-none');
    return;
  }

  empty.classList.add('d-none');
  grid.classList.remove('d-none');

  const categoryColors = {
    Technology: 'primary', Music: 'danger', Business: 'success',
    Sports: 'warning', Art: 'info', default: 'secondary'
  };

  grid.innerHTML = events.map(e => {
    const color = categoryColors[e.category] || categoryColors.default;
    const seatsClass = e.availableSeats > 50 ? '' : e.availableSeats > 10 ? 'low' : 'full';
    const date = new Date(e.date).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' });
    const time = new Date(e.date).toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' });
    const isFull = e.availableSeats === 0;

    return `
      <div class="col-md-6 col-lg-4" data-category="${e.category}" data-title="${e.title.toLowerCase()}" data-location="${e.location.toLowerCase()}">
        <div class="event-card card h-100">
          <img src="${e.imageUrl || 'https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=600'}"
               class="card-img-top" alt="${e.title}" loading="lazy"
               onerror="this.src='https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=600'">
          <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <span class="badge badge-category bg-${color}-subtle text-${color}">${e.category || 'General'}</span>
              <span class="seats-badge ${seatsClass}">
                <i class="bi bi-people"></i> ${isFull ? 'Sold out' : e.availableSeats + ' left'}
              </span>
            </div>
            <h5 class="card-title mb-2">${e.title}</h5>
            <p class="text-muted small mb-3 flex-grow-1">${e.description.substring(0,110)}${e.description.length>110?'…':''}</p>
            <div class="event-meta mb-3">
              <div class="mb-1"><i class="bi bi-geo-alt-fill text-danger"></i> ${e.location}</div>
              <div><i class="bi bi-calendar-event-fill text-primary"></i> ${date} · ${time}</div>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-auto">
              <span class="price-tag">₹${e.ticketPrice.toLocaleString('en-IN')}</span>
              <button class="btn btn-primary btn-sm rounded-pill px-3"
                      onclick="openBooking(${JSON.stringify(e).replace(/"/g,'&quot;')})"
                      ${isFull ? 'disabled' : ''}>
                ${isFull ? 'Sold Out' : '<i class=\'bi bi-ticket-perforated me-1\'></i>Book Now'}
              </button>
            </div>
          </div>
        </div>
      </div>`;
  }).join('');
}

// ── Client-side filter ─────────────────────────────────────────────────
function filterEvents() {
  const search = document.getElementById('searchInput').value.toLowerCase();
  const category = document.querySelector('input[name="category"]:checked')?.value || '';

  const filtered = allEvents.filter(e => {
    const matchCat = !category || e.category === category;
    const matchSearch = !search ||
      e.title.toLowerCase().includes(search) ||
      e.location.toLowerCase().includes(search) ||
      e.description.toLowerCase().includes(search);
    return matchCat && matchSearch;
  });
  renderEvents(filtered);
}

// ── Open booking modal ─────────────────────────────────────────────────
function openBooking(event) {
  if (!isLoggedIn()) {
    showToast('Please login to book tickets', 'info');
    setTimeout(() => window.location.href = '/Auth/Login', 1200);
    return;
  }

  currentEvent = event;
  document.getElementById('modalEventTitle').textContent = event.title;
  document.getElementById('modalLocation').textContent = event.location;
  document.getElementById('modalDate').textContent = new Date(event.date)
    .toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' });
  document.getElementById('modalPrice').textContent = event.ticketPrice.toLocaleString('en-IN');
  document.getElementById('modalSeats').textContent = event.availableSeats;

  const seatsInput = document.getElementById('seatsInput');
  seatsInput.max = Math.min(event.availableSeats, 50);
  seatsInput.value = 1;

  document.getElementById('bookingError').classList.add('d-none');
  document.getElementById('bookingSuccess').classList.add('d-none');
  document.getElementById('bookingForm').style.display = 'block';
  document.getElementById('bookingFooter').style.display = 'flex';

  updateTotal();
  new bootstrap.Modal(document.getElementById('bookingModal')).show();
}

function updateTotal() {
  const seats = parseInt(document.getElementById('seatsInput').value) || 0;
  const total = seats * (currentEvent?.ticketPrice || 0);
  document.getElementById('totalAmount').textContent = total.toLocaleString('en-IN');
  validateSeats();
}

// ── Client-side seat validation ────────────────────────────────────────
function validateSeats() {
  const input = document.getElementById('seatsInput');
  const err = document.getElementById('seatsError');
  const btn = document.getElementById('confirmBookBtn');
  const seats = parseInt(input.value);

  if (!seats || seats < 1) {
    input.classList.add('is-invalid');
    err.textContent = 'Please enter at least 1 seat.';
    btn.disabled = true; return false;
  }
  if (seats > currentEvent.availableSeats) {
    input.classList.add('is-invalid');
    err.textContent = `Only ${currentEvent.availableSeats} seats available.`;
    btn.disabled = true; return false;
  }
  if (seats > 50) {
    input.classList.add('is-invalid');
    err.textContent = 'Maximum 50 seats per booking.';
    btn.disabled = true; return false;
  }
  input.classList.remove('is-invalid');
  input.classList.add('is-valid');
  btn.disabled = false;
  return true;
}

// ── Submit booking ─────────────────────────────────────────────────────
async function submitBooking() {
  if (!validateSeats()) return;

  const btn = document.getElementById('confirmBookBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Booking...';

  try {
    const resp = await apiFetch('/api/bookings', {
      method: 'POST',
      body: JSON.stringify({
        eventId: currentEvent.id,
        seatsBooked: parseInt(document.getElementById('seatsInput').value)
      })
    });

    const data = await resp.json();

    if (resp.ok) {
      // Hide form, show success
      document.getElementById('bookingForm').style.display = 'none';
      document.getElementById('bookingFooter').style.display = 'none';
      const success = document.getElementById('bookingSuccess');
      success.innerHTML = `
        <div class="text-center py-2">
          <i class="bi bi-check-circle-fill text-success fs-1 d-block mb-2"></i>
          <strong>Booking Confirmed!</strong><br>
          <small class="text-muted">${data.seatsBooked} seat(s) for ${data.eventTitle}</small>
          <br><a href="/Bookings" class="btn btn-sm btn-outline-primary mt-2 rounded-pill">View My Bookings</a>
        </div>`;
      success.classList.remove('d-none');

      // Update available seats in UI
      currentEvent.availableSeats -= parseInt(document.getElementById('seatsInput').value);
      showToast('Booking confirmed! 🎉', 'success');
      loadEvents(); // refresh
    } else {
      document.getElementById('bookingError').textContent = data.title || data || 'Booking failed. Please try again.';
      document.getElementById('bookingError').classList.remove('d-none');
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-check2-circle me-1"></i>Confirm Booking';
    }
  } catch (err) {
    document.getElementById('bookingError').textContent = err.message;
    document.getElementById('bookingError').classList.remove('d-none');
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-check2-circle me-1"></i>Confirm Booking';
  }
}

loadEvents();
</script>
}