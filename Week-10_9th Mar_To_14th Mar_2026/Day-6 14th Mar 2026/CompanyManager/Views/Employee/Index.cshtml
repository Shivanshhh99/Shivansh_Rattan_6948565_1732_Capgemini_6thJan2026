@model IEnumerable<CompanyManager.Models.Employee>

<h2>Employees</h2>

<a asp-action="Create" class="btn btn-primary">Add Employee</a>

<table class="table table-bordered">
    <tr>
        <th>Employee Name</th>
        <th>Department</th>
    </tr>

    @foreach (var emp in Model)
    {
        <tr>
            <td>@emp.Name</td>
            <td>@emp.Department.Name</td>
        </tr>
    }
</table>