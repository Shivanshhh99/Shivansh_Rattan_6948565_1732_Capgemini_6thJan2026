@model IEnumerable<CompanyManager.Models.Project>

<h2>Project Dashboard</h2>

<table class="table table-bordered">

    <tr>
        <th>Project</th>
        <th>Employee</th>
        <th>Department</th>
        <th>Assigned Date</th>
    </tr>

    @foreach (var project in Model)
    {
        foreach (var ep in project.EmployeeProjects)
        {
            <tr>
                <td>@project.Title</td>
                <td>@ep.Employee.Name</td>
                <td>@ep.Employee.Department.Name</td>
                <td>@ep.AssignedDate</td>
            </tr>
        }
    }

</table>