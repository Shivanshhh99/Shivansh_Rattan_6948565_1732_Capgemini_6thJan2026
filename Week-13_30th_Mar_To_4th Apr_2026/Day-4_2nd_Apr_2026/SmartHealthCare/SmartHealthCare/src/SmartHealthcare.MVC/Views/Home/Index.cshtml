@{
    ViewData["Title"] = "Home";
    var token = Context.Session.GetString("Token");
}

<style>
    .hero {
        text-align: center;
        margin-bottom: 4rem;
    }

    .hero h1 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 1rem;
        background: linear-gradient(135deg, var(--primary-light), var(--accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero p {
        font-size: 1.1rem;
        color: var(--text-secondary);
        max-width: 600px;
        margin: 0 auto 2rem;
        line-height: 1.6;
    }

    .hero-buttons {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
        margin-bottom: 3rem;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-top: 3rem;
    }

    .stat-box {
        text-align: center;
        padding: 2rem 1.5rem;
        background: rgba(37, 45, 61, 0.4);
        border: 1px solid var(--border-color);
        border-radius: 1rem;
        transition: all 0.3s ease;
    }

    .stat-box:hover {
        background: rgba(37, 45, 61, 0.6);
        border-color: var(--accent);
        transform: translateY(-4px);
    }

    .stat-number {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--accent);
        margin-bottom: 0.5rem;
    }

    .stat-label {
        color: var(--text-secondary);
        font-weight: 600;
    }

    .features-section {
        margin: 4rem 0;
    }

    .section-title {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 1rem;
        color: var(--text-primary);
    }

    .section-subtitle {
        color: var(--text-secondary);
        font-size: 1.05rem;
        margin-bottom: 3rem;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin-top: 2rem;
    }

    .feature-box {
        background: linear-gradient(135deg, rgba(37, 45, 61, 0.6), rgba(26, 31, 46, 0.8));
        border: 1px solid var(--border-color);
        border-radius: 1.25rem;
        padding: 2.5rem 2rem;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .feature-box:hover {
        transform: translateY(-8px);
        border-color: var(--accent);
        box-shadow: 0 20px 48px rgba(0, 212, 255, 0.15);
    }

    .feature-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 1rem;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
    }

    .feature-box h3 {
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
        color: var(--text-primary);
    }

    .feature-box p {
        color: var(--text-secondary);
        margin: 0;
        line-height: 1.6;
        flex: 1;
        margin-bottom: 1.5rem;
    }

    .feature-box .btn {
        align-self: flex-start;
    }

    .cta-section {
        background: linear-gradient(135deg, rgba(0, 102, 255, 0.1), rgba(124, 58, 237, 0.1));
        border: 1px solid var(--border-color);
        border-radius: 1.5rem;
        padding: 4rem 2rem;
        text-align: center;
        margin: 4rem 0;
    }

    .cta-section h2 {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 1rem;
        color: var(--text-primary);
    }

    .cta-section p {
        color: var(--text-secondary);
        font-size: 1.05rem;
        margin-bottom: 2rem;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }
</style>

<!-- Hero Section -->
<div class="hero">
    <h1>Welcome to Smart Healthcare</h1>
    <p>Your complete solution for managing patients, doctors, appointments, and prescriptions from one intelligent dashboard</p>
    
    <div class="hero-buttons">
        @if (token == null)
        {
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">
                <i class="bi bi-person-plus me-2"></i>Get Started
            </a>
            <a asp-controller="Doctor" asp-action="Index" class="btn btn-outline-primary btn-lg">
                <i class="bi bi-search me-2"></i>Browse Doctors
            </a>
        }
        else
        {
            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lg">
                <i class="bi bi-speedometer2 me-2"></i>Go to Dashboard
            </a>
            <a asp-controller="Appointment" asp-action="Create" class="btn btn-outline-primary btn-lg">
                <i class="bi bi-calendar-check me-2"></i>Book Appointment
            </a>
        }
    </div>

    <!-- Stats -->
    <div class="stats-grid">
        <div class="stat-box">
            <div class="stat-number">24/7</div>
            <div class="stat-label">Available Support</div>
        </div>
        <div class="stat-box">
            <div class="stat-number">500+</div>
            <div class="stat-label">Qualified Doctors</div>
        </div>
        <div class="stat-box">
            <div class="stat-number">10K+</div>
            <div class="stat-label">Happy Patients</div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="features-section">
    <h2 class="section-title">Our Services</h2>
    <p class="section-subtitle">Comprehensive healthcare solutions tailored to your needs</p>
    
    <div class="features-grid">
        <!-- For Patients -->
        <div class="feature-box">
            <div class="feature-icon"><i class="bi bi-people"></i></div>
            <h3>For Patients</h3>
            <p>Book appointments with qualified doctors, review your care history, manage your medical profile, and receive digital prescriptions.</p>
            <a href="@Url.Action("Index", "Doctor")" class="btn btn-outline-primary btn-sm">Learn More</a>
        </div>

        <!-- For Doctors -->
        <div class="feature-box">
            <div class="feature-icon"><i class="bi bi-stethoscope"></i></div>
            <h3>For Doctors</h3>
            <p>Manage your patient schedule, track visits efficiently, issue prescriptions, and build your professional profile online.</p>
            <a href="@Url.Action("Register", "Account")" class="btn btn-outline-primary btn-sm">Register Now</a>
        </div>

        <!-- For Administrators -->
        <div class="feature-box">
            <div class="feature-icon"><i class="bi bi-graph-up"></i></div>
            <h3>For Administrators</h3>
            <p>Monitor system performance, manage users, generate health reports, and ensure smooth operations of the healthcare network.</p>
            <a href="@Url.Action("Login", "Account")" class="btn btn-outline-primary btn-sm">Admin Panel</a>
        </div>
    </div>
</div>

<!-- Why Choose Us -->
<div class="features-section">
    <h2 class="section-title">Why Choose Smart Healthcare?</h2>
    <p class="section-subtitle">We're committed to making healthcare accessible, affordable, and efficient</p>
    
    <div class="features-grid">
        <div class="feature-box">
            <div class="feature-icon" style="background: linear-gradient(135deg, #10b981, #059669);"><i class="bi bi-check-circle"></i></div>
            <h3>Easy Booking</h3>
            <p>Book appointments in seconds with our intuitive scheduling system. No complicated forms or long wait times.</p>
        </div>

        <div class="feature-box">
            <div class="feature-icon" style="background: linear-gradient(135deg, #f59e0b, #d97706);"><i class="bi bi-star"></i></div>
            <h3>Verified Professionals</h3>
            <p>Access to verified and experienced doctors across multiple specializations. Each professional is thoroughly vetted.</p>
        </div>

        <div class="feature-box">
            <div class="feature-icon" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed);"><i class="bi bi-file-earmark-check"></i></div>
            <h3>Digital Prescriptions</h3>
            <p>Receive and manage prescriptions digitally from anywhere. No more paper or lost prescriptions.</p>
        </div>

        <div class="feature-box">
            <div class="feature-icon" style="background: linear-gradient(135deg, #06b6d4, #0891b2);"><i class="bi bi-shield-lock"></i></div>
            <h3>Secure & Private</h3>
            <p>Your medical data is encrypted and protected with industry-standard security. Your privacy is our priority.</p>
        </div>

        <div class="feature-box">
            <div class="feature-icon" style="background: linear-gradient(135deg, #ec4899, #db2777);"><i class="bi bi-clock"></i></div>
            <h3>Available 24/7</h3>
            <p>Access our platform anytime, anywhere on any device. Healthcare at your convenience.</p>
        </div>

        <div class="feature-box">
            <div class="feature-icon" style="background: linear-gradient(135deg, #14b8a6, #0d9488);"><i class="bi bi-lightning-charge"></i></div>
            <h3>Fast & Reliable</h3>
            <p>Lightning-fast appointment confirmations and real-time updates. Experience healthcare reimagined.</p>
        </div>
    </div>
</div>

<!-- CTA Section -->
<div class="cta-section">
    <h2>Ready to Join Our Healthcare Community?</h2>
    <p>Start your journey towards better health management today. Thousands of patients and doctors trust Smart Healthcare.</p>
    @if (token == null)
    {
        <div class="d-flex flex-wrap justify-content-center gap-2">
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">
                <i class="bi bi-person-plus me-2"></i>Sign Up Now
            </a>
            <a asp-controller="Doctor" asp-action="Index" class="btn btn-outline-primary btn-lg">
                <i class="bi bi-search me-2"></i>Explore Doctors
            </a>
        </div>
    }
</div>
