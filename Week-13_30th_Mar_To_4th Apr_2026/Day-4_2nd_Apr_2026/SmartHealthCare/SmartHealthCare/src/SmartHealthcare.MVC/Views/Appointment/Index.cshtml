@model IEnumerable<SmartHealthcare.Models.DTOs.AppointmentDTO>
@{
    ViewData["Title"] = "My Appointments";
    var role = ViewBag.Role as string;
}

<style>
    .appointments-header {
        margin-bottom: 2rem;
    }

    .appointments-header h1 {
        font-size: 2rem;
        font-weight: 800;
        color: var(--text-primary);
    }

    .appointment-card {
        background: rgba(37, 45, 61, 0.5);
        border: 1px solid var(--border-color) !important;
        border-radius: 1.25rem;
        transition: all 0.3s ease;
        overflow: hidden;
    }

    .appointment-card:hover {
        transform: translateY(-8px);
        border-color: var(--accent) !important;
        box-shadow: 0 20px 48px rgba(0, 212, 255, 0.15) !important;
        background: rgba(37, 45, 61, 0.8);
    }

    .appointment-card .card-header {
        border: none;
        padding: 1.25rem;
        background: linear-gradient(135deg, var(--primary), var(--secondary)) !important;
    }

    .appointment-card .card-body {
        padding: 1.5rem;
        background: transparent;
    }

    .appointment-info {
        background: rgba(0, 212, 255, 0.05);
        padding: 1rem;
        border-radius: 0.75rem;
        border-left: 3px solid var(--accent);
    }

    .appointment-card .card-footer {
        background: transparent !important;
        border-top: 1px solid var(--border-light);
        padding: 1rem;
    }

    .appointment-info strong {
        color: var(--text-primary);
    }

    .appointment-info p {
        color: var(--text-secondary);
        margin-bottom: 0.75rem;
    }
</style>

<div class="container py-4">
    <div class="appointments-header d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-calendar-check me-2"></i>My Appointments</h1>
            <p class="text-muted">View and manage your scheduled appointments</p>
        </div>
        @if (role == "Patient")
        {
            <a asp-action="Create" class="btn btn-success btn-lg">
                <i class="bi bi-plus-circle me-2"></i>Book New
            </a>
        }
    </div>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm appointment-card">
                        <div class="card-header">
                            <div class="d-flex justify-content-between align-items-center">
                                <h6 class="mb-0" style="color: white;"><i class="bi bi-calendar-event me-2"></i>Appointment #@item.Id</h6>
                                <span class="badge" style="background: rgba(255,255,255,0.2); color: white;">@item.Status</span>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="appointment-info">
                                <p class="mb-2">
                                    <strong><i class="bi bi-person me-2"></i>Patient:</strong><br />
                                    <span class="ms-4">@item.PatientName</span>
                                </p>
                                <p class="mb-2">
                                    <strong><i class="bi bi-stethoscope me-2"></i>Doctor:</strong><br />
                                    <span class="ms-4">Dr. @item.DoctorName</span>
                                </p>
                                <p class="mb-0">
                                    <strong><i class="bi bi-clock me-2"></i>Date & Time:</strong><br />
                                    <span class="ms-4">@item.AppointmentDate.ToString("dd-MMM-yyyy HH:mm")</span>
                                </p>
                                @if (!string.IsNullOrEmpty(item.Notes))
                                {
                                    <hr style="border-color: var(--border-light); margin: 0.75rem 0;" />
                                    <p class="mb-0">
                                        <strong><i class="bi bi-sticky me-2"></i>Notes:</strong><br />
                                        <span class="ms-4 text-muted">@item.Notes</span>
                                    </p>
                                }
                            </div>
                        </div>
                        <div class="card-footer">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary w-100 btn-sm">
                                <i class="bi bi-info-circle me-2"></i>View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5" role="alert">
            <h4 class="alert-heading"><i class="bi bi-info-circle me-2"></i>No Appointments</h4>
            <p class="mb-3">You haven't booked any appointments yet.</p>
            @if (role == "Patient")
            {
                <a asp-action="Create" class="btn btn-info">
                    <i class="bi bi-plus-circle me-2"></i>Book Your First Appointment
                </a>
            }
        </div>
    }
</div>

@functions {
    private string GetStatusColor(string status)
    {
        return status?.ToLower() switch
        {
            "pending" => "warning",
            "completed" => "success",
            "cancelled" => "danger",
            _ => "secondary"
        };
    }
}