@page
@model DashboardModel

<h2>Transactions</h2>

<table border="1">
    <tr>
        <th>Amount</th>
        <th>Date</th>
        <th>Type</th>
    </tr>

    @foreach (var t in Model.Transactions)
    {
        <tr>
            <td>@t.Amount</td>
            <td>@t.Date</td>
            <td>@t.Type</td>
        </tr>
    }
</table>

<form method="post" asp-page-handler="Logout">
    <button type="submit">Logout</button>
</form>