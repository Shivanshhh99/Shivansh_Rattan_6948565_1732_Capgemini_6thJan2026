@model SmartHospital.MVC.Models.ViewModels.BookAppointmentViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Book Appointment";
}

<div class="form-card" style="max-width:700px;">
    <div class="mb-4">
        <h2>Book an Appointment</h2>
        <p class="text-muted" style="font-size:0.88rem;">Choose your doctor and preferred time</p>
    </div>

    <!-- Department Quick Filter -->
    @if (ViewBag.Departments != null)
    {
        <div class="mb-4">
            <label class="form-label fw-600">Filter by Department</label>
            <div class="d-flex flex-wrap gap-2">
                <a href="/Appointments/Book" class="btn btn-sm @(ViewBag.SelectedDepartment == null ? "btn-primary" : "btn-outline-secondary")">All</a>
                @foreach (var dept in ViewBag.Departments)
                {
                    var deptId = dept.GetProperty("departmentId").GetInt32();
                    <a href="/Appointments/Book?departmentId=@deptId" class="btn btn-sm @(ViewBag.SelectedDepartment?.ToString() == deptId.ToString() ? "btn-primary" : "btn-outline-secondary")">
                        @dept.GetProperty("departmentName").GetString()
                    </a>
                }
            </div>
        </div>
    }

    <form asp-action="Book" method="post" novalidate id="bookForm">
        @Html.AntiForgeryToken()
        <input asp-for="PatientId" type="hidden"/>
        <input asp-for="FilterDepartmentId" type="hidden"/>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3" style="font-size:0.85rem;"></div>

        <div class="mb-3">
            <label asp-for="DoctorId" class="form-label">Select Doctor</label>
            <select asp-for="DoctorId" class="form-select" id="doctorSelect">
                <option value="">-- Choose a doctor --</option>
                @if (ViewBag.Doctors != null)
                {
                    @foreach (var doc in ViewBag.Doctors)
                    {
                        <option value="@doc.GetProperty("doctorId").GetInt32()"
                                data-spec="@doc.GetProperty("specialization").GetString()"
                                data-avail="@doc.GetProperty("availability").GetString()"
                                data-exp="@doc.GetProperty("experienceYears").GetInt32()">
                            Dr. @doc.GetProperty("fullName").GetString() – @doc.GetProperty("departmentName").GetString()
                        </option>
                    }
                }
            </select>
            <span asp-validation-for="DoctorId" class="field-validation-error"></span>
        </div>

        <!-- Doctor Info Card (shown on select) -->
        <div id="doctorInfo" class="p-3 mb-3 rounded-3 d-none" style="background:var(--accent);border:1px solid var(--border);">
            <div class="d-flex align-items-center gap-3">
                <div class="doctor-avatar" style="width:44px;height:44px;font-size:1rem;">D</div>
                <div>
                    <div class="fw-600" id="infoSpec">Specialization</div>
                    <small class="text-muted" id="infoAvail">Availability</small>
                </div>
                <div class="ms-auto text-end">
                    <div class="fw-600" id="infoExp">0 yrs</div>
                    <small class="text-muted">Experience</small>
                </div>
            </div>
        </div>

        <div class="mb-4">
            <label asp-for="AppointmentDate" class="form-label">Appointment Date & Time</label>
            <input asp-for="AppointmentDate" class="form-control" type="datetime-local"
                   min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"/>
            <span asp-validation-for="AppointmentDate" class="field-validation-error"></span>
            <small class="text-muted mt-1 d-block">
                <i class="bi bi-info-circle me-1"></i>Note: Slots are 30 minutes. Please ensure your chosen time doesn't conflict.
            </small>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-calendar-check me-2"></i>Confirm Booking
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
    document.getElementById('doctorSelect').addEventListener('change', function() {
        const opt = this.options[this.selectedIndex];
        const infoDiv = document.getElementById('doctorInfo');
        if (opt.value) {
            document.getElementById('infoSpec').textContent = opt.dataset.spec || 'General';
            document.getElementById('infoAvail').textContent = opt.dataset.avail || 'Contact for schedule';
            document.getElementById('infoExp').textContent = opt.dataset.exp + ' yrs';
            infoDiv.classList.remove('d-none');
        } else {
            infoDiv.classList.add('d-none');
        }
    });
    </script>
}