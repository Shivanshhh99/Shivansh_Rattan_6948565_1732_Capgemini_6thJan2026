<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Hospital</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var isLoggedIn = Context.Session.GetString("JwtToken") != null;
        var role = Context.Session.GetString("UserRole");
        var userName = Context.Session.GetString("UserName");
    }

    @if (isLoggedIn)
    {
        <div class="sidebar" id="sidebar">
            <div class="sidebar-brand">
                <i class="bi bi-heart-pulse-fill"></i>
                <span>SmartHospital</span>
            </div>
            <nav class="sidebar-nav">
                @if (role == "Admin")
                {
                    <a asp-controller="Admin" asp-action="Dashboard" class="nav-link">
                        <i class="bi bi-speedometer2"></i> Admin Dashboard
                    </a>
                    <a asp-controller="Admin" asp-action="Users" class="nav-link">
                        <i class="bi bi-people"></i> Users
                    </a>
                    <a asp-controller="Admin" asp-action="Doctors" class="nav-link">
                        <i class="bi bi-person-badge"></i> Doctors
                    </a>
                    <a asp-controller="Admin" asp-action="Appointments" class="nav-link">
                        <i class="bi bi-calendar-check"></i> Appointments
                    </a>
                    <a asp-controller="Admin" asp-action="Billing" class="nav-link">
                        <i class="bi bi-receipt"></i> Billing
                    </a>
                    <a asp-controller="Admin" asp-action="Prescriptions" class="nav-link">
                        <i class="bi bi-prescription2"></i> Prescriptions
                    </a>
                    <a asp-controller="Admin" asp-action="Departments" class="nav-link">
                        <i class="bi bi-building"></i> Departments
                    </a>
                }
                else
                {
                    <a asp-controller="Dashboard" asp-action="Index" class="nav-link">
                        <i class="bi bi-grid-1x2"></i> Dashboard
                    </a>
                    <a asp-controller="Doctors" asp-action="Index" class="nav-link">
                        <i class="bi bi-person-badge"></i> Doctors
                    </a>
                    @if (role == "Patient")
                    {
                        <a asp-controller="Appointments" asp-action="Book" class="nav-link">
                            <i class="bi bi-calendar-plus"></i> Book Appointment
                        </a>
                    }
                    <a asp-controller="Appointments" asp-action="Index" class="nav-link">
                        <i class="bi bi-calendar-check"></i> Appointments
                    </a>
                    @if (role == "Patient" || role == "Doctor")
                    {
                        <a asp-controller="Prescriptions" asp-action="Index" class="nav-link">
                            <i class="bi bi-prescription2"></i> Prescriptions
                        </a>
                    }
                    @if (role == "Patient")
                    {
                        <a asp-controller="Bills" asp-action="Index" class="nav-link">
                            <i class="bi bi-receipt"></i> My Bills
                        </a>
                    }
                    @if (role == "Admin")
                    {
                        <a asp-controller="Doctors" asp-action="Create" class="nav-link">
                            <i class="bi bi-person-plus"></i> Add Doctor
                        </a>
                    }
                }
            </nav>
            <div class="sidebar-footer">
                <div class="user-info">
                    <div class="user-avatar">@(userName?.Substring(0,1).ToUpper())</div>
                    <div>
                        <div class="user-name">@userName</div>
                        <div class="user-role">@role</div>
                    </div>
                </div>
                <a asp-controller="Auth" asp-action="Logout" class="btn-logout">
                    <i class="bi bi-box-arrow-right"></i>
                </a>
            </div>
        </div>

        <div class="main-content" id="mainContent">
            <div class="top-bar">
                <button class="sidebar-toggle" id="sidebarToggle">
                    <i class="bi bi-list"></i>
                </button>
                <div class="page-title">@ViewData["Title"]</div>
                <div class="top-bar-right">
                    <span class="badge-role badge-@(role?.ToLower())">@role</span>
                </div>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert-toast alert-success-toast" id="successToast">
                    <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert-toast alert-error-toast" id="errorToast">
                    <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
                </div>
            }

            <div class="content-area">
                @RenderBody()
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>