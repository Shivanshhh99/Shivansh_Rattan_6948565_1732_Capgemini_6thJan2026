@model SmartHospital.MVC.Models.ViewModels.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Register";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Register – Smart Hospital</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body>
<div class="auth-wrapper">
    <div class="auth-left">
        <div>
            <div class="auth-logo">
                <i class="bi bi-heart-pulse-fill" style="color:#4ecdc4"></i> SmartHospital
            </div>
            <p class="auth-tagline">Join thousands of patients<br>managing their health smarter.</p>
            <div class="mt-4">
                <div class="d-flex align-items-center gap-3 mb-3" style="opacity:0.85;">
                    <div style="width:36px;height:36px;background:rgba(255,255,255,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-calendar-check"></i>
                    </div>
                    <div><strong>Easy Booking</strong><br><small style="opacity:0.75;">Book appointments in seconds</small></div>
                </div>
                <div class="d-flex align-items-center gap-3 mb-3" style="opacity:0.85;">
                    <div style="width:36px;height:36px;background:rgba(255,255,255,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-file-medical"></i>
                    </div>
                    <div><strong>Medical Records</strong><br><small style="opacity:0.75;">Access prescriptions anytime</small></div>
                </div>
                <div class="d-flex align-items-center gap-3" style="opacity:0.85;">
                    <div style="width:36px;height:36px;background:rgba(255,255,255,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-receipt"></i>
                    </div>
                    <div><strong>Billing Transparency</strong><br><small style="opacity:0.75;">Clear, itemized bills</small></div>
                </div>
            </div>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-form">
            <h2 style="font-family:'DM Serif Display',serif;font-size:1.8rem;margin-bottom:4px;">Create Account</h2>
            <p style="color:#6b7a8d;font-size:0.9rem;margin-bottom:24px;">Register as a patient — free & secure</p>

            <form asp-action="Register" asp-controller="Auth" method="post" novalidate id="registerForm">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" placeholder="Dr. John Smith"/>
                    <span asp-validation-for="FullName" class="field-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" placeholder="your@email.com" type="email"/>
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="input-group">
                        <input asp-for="Password" class="form-control" type="password" placeholder="Min. 8 characters" id="Password" style="border-right:none;"/>
                        <button type="button" class="input-group-text" style="background:#f8f9fa;cursor:pointer;" onclick="togglePwd('Password',this)">
                            <i class="bi bi-eye" style="color:#6b7a8d;"></i>
                        </button>
                    </div>
                    <div class="mt-2">
                        <div style="height:4px;background:#e9ecef;border-radius:4px;overflow:hidden;">
                            <div id="passwordStrengthBar" style="height:100%;width:0;transition:all 0.3s;border-radius:4px;"></div>
                        </div>
                        <small id="passwordStrengthLabel" style="font-size:0.75rem;margin-top:2px;display:block;"></small>
                    </div>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Repeat password"/>
                    <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">
                    <i class="bi bi-person-plus me-2"></i>Create Account
                </button>
            </form>

            <hr class="my-4" style="border-color:#dde4e2;"/>
            <p class="text-center" style="font-size:0.88rem;color:#6b7a8d;">
                Already have an account?
                <a asp-controller="Auth" asp-action="Login" style="color:var(--primary);font-weight:600;">Sign in</a>
            </p>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
<script src="~/js/site.js"></script>
<script>
function togglePwd(id, btn) {
    const inp = document.getElementById(id);
    const icon = btn.querySelector('i');
    if (inp.type === 'password') { inp.type = 'text'; icon.className = 'bi bi-eye-slash'; }
    else { inp.type = 'password'; icon.className = 'bi bi-eye'; }
}
</script>
</body>
</html>