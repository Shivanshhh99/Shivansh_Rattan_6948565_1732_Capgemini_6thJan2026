@model SmartHospital.MVC.Models.ViewModels.CreateDoctorViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Add Doctor";
}

<div class="form-card">
    <div class="mb-4">
        <h2>Add New Doctor</h2>
        <p class="text-muted" style="font-size:0.88rem;">Create a doctor account and assign to a department</p>
    </div>

    <form asp-action="Create" method="post" novalidate id="createDoctorForm">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3 rounded-3" style="font-size:0.85rem;"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" placeholder="Dr. Sarah Ahmed"/>
                <span asp-validation-for="FullName" class="field-validation-error"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="doctor@hospital.com" type="email"/>
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Secure password"/>
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="DepartmentId" class="form-label"></label>
                <select asp-for="DepartmentId" class="form-select">
                    <option value="">-- Select Department --</option>
                    @if (ViewBag.Departments != null)
                    {
                        @foreach (var dept in ViewBag.Departments)
                        {
                            <option value="@dept.GetProperty("departmentId").GetInt32()">
                                @dept.GetProperty("departmentName").GetString()
                            </option>
                        }
                    }
                </select>
                <span asp-validation-for="DepartmentId" class="field-validation-error"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Specialization" class="form-label"></label>
                <input asp-for="Specialization" class="form-control" placeholder="e.g. Interventional Cardiology"/>
                <span asp-validation-for="Specialization" class="field-validation-error"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="ExperienceYears" class="form-label"></label>
                <input asp-for="ExperienceYears" class="form-control" type="number" min="0" max="50"/>
                <span asp-validation-for="ExperienceYears" class="field-validation-error"></span>
            </div>
            <div class="col-12">
                <label asp-for="Availability" class="form-label"></label>
                <input asp-for="Availability" class="form-control" placeholder="e.g. Mon-Fri 9am-5pm, Sat 9am-1pm"/>
                <span asp-validation-for="Availability" class="field-validation-error"></span>
            </div>
        </div>

        <div class="mt-4 d-flex gap-3">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-person-plus me-2"></i>Create Doctor
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
}