@using System.Text.Json
@model JsonElement
@{
    ViewData["Title"] = "Doctor Profile";
    var doctorId = Model.GetProperty("doctorId").GetInt32();
    var fullName = Model.GetProperty("fullName").GetString() ?? "";
    var email = Model.GetProperty("email").GetString() ?? "";
    var department = Model.GetProperty("departmentName").GetString() ?? "";
    var specialization = Model.GetProperty("specialization").GetString() ?? "";
    var experience = Model.GetProperty("experienceYears").GetInt32();
    var availability = Model.GetProperty("availability").GetString() ?? "";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <!-- Back Button -->
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary mb-3">
                <i class="bi bi-arrow-left"></i> Back to Doctors
            </a>

            <!-- Doctor Profile Card -->
            <div class="card shadow-lg">
                <div class="card-body p-5">
                    <div class="row">
                        <div class="col-md-4 text-center">
                            <!-- Doctor Avatar -->
                            <div class="doctor-avatar-large">
                                @fullName[0].ToString().ToUpper()
                            </div>
                            <h3 class="mt-3">@fullName</h3>
                            <p class="text-muted">@specialization</p>
                        </div>

                        <div class="col-md-8">
                            <!-- Doctor Information -->
                            <div class="doctor-details">
                                <div class="detail-item mb-3">
                                    <label class="text-muted small">Department</label>
                                    <p class="mb-0">
                                        <span class="badge bg-primary">@department</span>
                                    </p>
                                </div>

                                <div class="detail-item mb-3">
                                    <label class="text-muted small">Email</label>
                                    <p class="mb-0">
                                        <i class="bi bi-envelope"></i> 
                                        <a href="mailto:@email">@email</a>
                                    </p>
                                </div>

                                <div class="detail-item mb-3">
                                    <label class="text-muted small">Experience</label>
                                    <p class="mb-0">
                                        <i class="bi bi-briefcase"></i> @experience years of experience
                                    </p>
                                </div>

                                <div class="detail-item mb-3">
                                    <label class="text-muted small">Availability</label>
                                    <p class="mb-0">
                                        <i class="bi bi-clock"></i> @availability
                                    </p>
                                </div>

                                <div class="detail-item">
                                    <label class="text-muted small">Status</label>
                                    <p class="mb-0">
                                        <span class="badge bg-success">Available for consultation</span>
                                    </p>
                                </div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="mt-4 d-flex gap-2">
                                <a asp-controller="Appointments" asp-action="Book" asp-route-doctorId="@doctorId" 
                                   class="btn btn-primary flex-grow-1">
                                    <i class="bi bi-calendar-plus"></i> Book Appointment
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Additional Information -->
            <div class="card mt-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">About This Doctor</h5>
                </div>
                <div class="card-body">
                    <p>
                        Dr. @fullName is a qualified medical professional specializing in @specialization with @experience years of 
                        clinical experience. They are available at our @department department and can be reached at @email for any 
                        inquiries or appointment bookings.
                    </p>
                    <p class="mb-0">
                        <strong>Consultation Hours:</strong> @availability
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .doctor-avatar-large {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        font-weight: bold;
        margin: 0 auto;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

    .doctor-details .detail-item label {
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .doctor-details p {
        font-size: 1.05rem;
    }
</style>
