@using System.Text.Json
@model CreatePrescriptionViewModel
@{
    ViewData["Title"] = "Write Prescription";
    var appointment = (JsonElement)ViewBag.Appointment;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="mb-0">Write Prescription</h3>
                <a asp-controller="Appointments" asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
            </div>

            <div class="card mb-3">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="text-muted small">Patient</label>
                            <div>@appointment.GetProperty("patientName").GetString()</div>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Doctor</label>
                            <div>@appointment.GetProperty("doctorName").GetString()</div>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Appointment Date</label>
                            <div>@DateTime.Parse(appointment.GetProperty("appointmentDate").GetString() ?? "").ToString("dd-MMM-yyyy HH:mm")</div>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Status</label>
                            <div>@appointment.GetProperty("status").GetString()</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Create" asp-route-appointmentId="@Model.AppointmentId" method="post">
                        <input type="hidden" asp-for="AppointmentId" />

                        <div class="mb-3">
                            <label asp-for="Diagnosis" class="form-label"></label>
                            <input asp-for="Diagnosis" class="form-control" placeholder="Diagnosis summary" />
                            <span asp-validation-for="Diagnosis" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Medicines" class="form-label"></label>
                            <textarea asp-for="Medicines" class="form-control" rows="4" placeholder="Medicine names, dose, frequency"></textarea>
                            <span asp-validation-for="Medicines" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Additional instructions"></textarea>
                            <span asp-validation-for="Notes" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-controller="Appointments" asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">Save Prescription</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
