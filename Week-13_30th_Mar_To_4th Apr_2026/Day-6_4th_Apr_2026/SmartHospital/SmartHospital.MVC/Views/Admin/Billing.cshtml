@model List<AdminBillViewModel>
@{
    ViewData["Title"] = "Billing Management";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>
                <i class="fas fa-file-invoice-dollar"></i> Billing Management
            </h1>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="CreateBill" class="btn btn-success me-2">
                <i class="fas fa-plus-circle"></i> Create Bill
            </a>
            <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card">
        <div class="card-header">
            <h5>
                <i class="fas fa-list"></i> All Bills (@Model.Count)
            </h5>
        </div>
        <div class="card-body">
            @if (Model.Count == 0)
            {
                <div class="text-center text-muted py-4">
                    <i class="fas fa-inbox" style="font-size: 3rem;"></i>
                    <p class="mt-3">No bills found</p>
                    <a asp-action="CreateBill" class="btn btn-primary btn-sm">
                        <i class="fas fa-plus"></i> Create First Bill
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Bill ID</th>
                                <th>Appointment ID</th>
                                <th>Patient</th>
                                <th>Doctor</th>
                                <th>Consultation</th>
                                <th>Medicines</th>
                                <th>Total</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var bill in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-primary">@bill.BillId</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@bill.AppointmentId</span>
                                    </td>
                                    <td>@bill.PatientName</td>
                                    <td>@bill.DoctorName</td>
                                    <td>
                                        <strong>Rs. @bill.ConsultationFee.ToString("N2")</strong>
                                    </td>
                                    <td>
                                        Rs. @bill.MedicineCharges.ToString("N2")
                                    </td>
                                    <td>
                                        <strong>Rs. @bill.TotalAmount.ToString("N2")</strong>
                                    </td>
                                    <td>
                                        @if (bill.PaymentStatus == "Paid")
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check-circle"></i> @bill.PaymentStatus
                                            </span>
                                        }
                                        else if (bill.PaymentStatus == "Unpaid")
                                        {
                                            <span class="badge bg-warning">
                                                <i class="fas fa-clock"></i> @bill.PaymentStatus
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@bill.PaymentStatus</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
