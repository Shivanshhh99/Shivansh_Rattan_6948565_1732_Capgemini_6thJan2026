@model List<AdminAppointmentViewModel>
@{
    ViewData["Title"] = "Appointments";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>
                <i class="fas fa-calendar-check"></i> Appointment Management
            </h1>
        </div>
        <div class="col-md-6 text-end">
            <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card">
        <div class="card-header">
            <h5>
                <i class="fas fa-list"></i> All Appointments (@Model.Count)
            </h5>
        </div>
        <div class="card-body">
            @if (Model.Count == 0)
            {
                <div class="text-center text-muted py-4">
                    <i class="fas fa-inbox" style="font-size: 3rem;"></i>
                    <p class="mt-3">No appointments found</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Appointment ID</th>
                                <th>Patient</th>
                                <th>Doctor</th>
                                <th>Appointment Date</th>
                                <th>Current Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var appointment in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-primary">@appointment.AppointmentId</span>
                                    </td>
                                    <td>@appointment.PatientName</td>
                                    <td>@appointment.DoctorName</td>
                                    <td>@appointment.AppointmentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (appointment.Status == "Booked")
                                        {
                                            <span class="badge bg-info">@appointment.Status</span>
                                        }
                                        else if (appointment.Status == "Completed")
                                        {
                                            <span class="badge bg-success">@appointment.Status</span>
                                        }
                                        else if (appointment.Status == "Cancelled")
                                        {
                                            <span class="badge bg-danger">@appointment.Status</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@appointment.Status</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <form asp-action="UpdateAppointmentStatus" method="post" style="display:inline-block;">
                                                <input type="hidden" name="appointmentId" value="@appointment.AppointmentId" />
                                                <select name="newStatus" class="form-select form-select-sm" style="width: 150px; display: inline-block;" 
                                                        onchange="this.parentElement.submit();">
                                                    <option value="">-- Change Status --</option>
                                                    @if (appointment.Status != "Booked")
                                                    {
                                                        <option value="Booked">Booked</option>
                                                    }
                                                    @if (appointment.Status != "Completed")
                                                    {
                                                        <option value="Completed">Completed</option>
                                                    }
                                                    @if (appointment.Status != "Cancelled")
                                                    {
                                                        <option value="Cancelled">Cancelled</option>
                                                    }
                                                </select>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
