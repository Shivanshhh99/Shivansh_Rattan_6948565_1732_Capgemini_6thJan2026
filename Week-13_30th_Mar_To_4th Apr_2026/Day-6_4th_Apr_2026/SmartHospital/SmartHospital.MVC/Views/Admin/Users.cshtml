@model List<AdminUserViewModel>
@{
    ViewData["Title"] = "User Management";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>
                <i class="fas fa-users"></i> User Management
            </h1>
        </div>
        <div class="col-md-6 text-end">
            <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card">
        <div class="card-header">
            <h5>
                <i class="fas fa-list"></i> All Users (@Model.Count)
            </h5>
        </div>
        <div class="card-body">
            @if (Model.Count == 0)
            {
                <div class="text-center text-muted py-4">
                    <i class="fas fa-inbox" style="font-size: 3rem;"></i>
                    <p class="mt-3">No users found</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>User ID</th>
                                <th>Full Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Created At</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-secondary">@user.UserId</span>
                                    </td>
                                    <td>@user.FullName</td>
                                    <td>@user.Email</td>
                                    <td>
                                        @if (user.Role == "Admin")
                                        {
                                            <span class="badge bg-danger">
                                                <i class="fas fa-shield-alt"></i> @user.Role
                                            </span>
                                        }
                                        else if (user.Role == "Doctor")
                                        {
                                            <span class="badge bg-info">
                                                <i class="fas fa-stethoscope"></i> @user.Role
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-user"></i> @user.Role
                                            </span>
                                        }
                                    </td>
                                    <td>@user.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (user.Role != "Admin")
                                        {
                                            <form method="post" action="@Url.Action("DeleteUser", "Admin")" style="display:inline;"
                                                  onsubmit="return confirm('Are you sure you want to delete this user?');">
                                                <input type="hidden" name="userId" value="@user.UserId" />
                                                <button type="submit" class="btn btn-sm btn-danger" title="Delete User">
                                                    <i class="fas fa-trash"></i> Delete
                                                </button>
                                            </form>
                                        }
                                        @if (user.Role == "Admin")
                                        {
                                            <span class="badge bg-secondary">Protected</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
