@model List<AdminPrescriptionViewModel>
@{
    ViewData["Title"] = "Prescription Management";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>
                <i class="fas fa-prescription"></i> Prescription Management
            </h1>
        </div>
        <div class="col-md-6 text-end">
            <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5>
                <i class="fas fa-list"></i> All Prescriptions (@Model.Count)
            </h5>
        </div>
        <div class="card-body">
            @if (Model.Count == 0)
            {
                <div class="text-center text-muted py-4">
                    <i class="fas fa-inbox" style="font-size: 3rem;"></i>
                    <p class="mt-3">No prescriptions found</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Appointment</th>
                                <th>Patient</th>
                                <th>Doctor</th>
                                <th>Date</th>
                                <th>Diagnosis</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var prescription in Model)
                            {
                                <tr>
                                    <td>@prescription.PrescriptionId</td>
                                    <td>@prescription.AppointmentId</td>
                                    <td>@prescription.PatientName</td>
                                    <td>@prescription.DoctorName</td>
                                    <td>@prescription.AppointmentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@prescription.Diagnosis</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
