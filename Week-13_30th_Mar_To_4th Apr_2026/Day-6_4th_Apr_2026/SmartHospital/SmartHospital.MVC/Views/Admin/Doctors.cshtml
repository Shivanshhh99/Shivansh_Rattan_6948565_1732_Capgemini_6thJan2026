@model List<AdminDoctorViewModel>
@{
    ViewData["Title"] = "Doctor Management";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>
                <i class="fas fa-users-md"></i> Doctor Management
            </h1>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="CreateDoctor" class="btn btn-success me-2">
                <i class="fas fa-plus-circle"></i> Add New Doctor
            </a>
            <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card">
        <div class="card-header">
            <h5>
                <i class="fas fa-stethoscope"></i> All Doctors (@Model.Count)
            </h5>
        </div>
        <div class="card-body">
            @if (Model.Count == 0)
            {
                <div class="text-center text-muted py-4">
                    <i class="fas fa-inbox" style="font-size: 3rem;"></i>
                    <p class="mt-3">No doctors found</p>
                    <a asp-action="CreateDoctor" class="btn btn-primary btn-sm">
                        <i class="fas fa-plus"></i> Add First Doctor
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Doctor ID</th>
                                <th>Full Name</th>
                                <th>Email</th>
                                <th>Department</th>
                                <th>Specialization</th>
                                <th>Experience (Years)</th>
                                <th>Consultation Fee</th>
                                <th>Availability</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doctor in Model)
                            {
                                <tr>
                                    <td>@doctor.DoctorId</td>
                                    <td>@doctor.FullName</td>
                                    <td>@doctor.Email</td>
                                    <td>@doctor.DepartmentName</td>
                                    <td>@doctor.Specialization</td>
                                    <td>@doctor.ExperienceYears</td>
                                    <td>Rs. @doctor.ConsultationFee.ToString("N2")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(doctor.Availability))
                                        {
                                            <span class="badge bg-success">Available</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Not Available</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="EditDoctor" asp-route-id="@doctor.DoctorId" class="btn btn-warning btn-sm me-1" title="Edit Doctor">
                                            <i class="fas fa-edit"></i> Edit
                                        </a>
                                        <form asp-action="DeleteDoctor" asp-route-id="@doctor.DoctorId" method="post" style="display:inline-block;"
                                              onsubmit="return confirm('Are you sure you want to delete this doctor?');">
                                            <button type="submit" class="btn btn-danger btn-sm" title="Delete Doctor">
                                                <i class="fas fa-trash"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
