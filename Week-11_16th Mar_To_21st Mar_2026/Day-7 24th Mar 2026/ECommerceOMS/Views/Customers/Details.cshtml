@model ECommerceOMS.Models.Customer
@{
    ViewData["Title"] = "Customer Details";

    string GetStatusBadge(ECommerceOMS.Models.OrderStatus status)
    {
        return status switch
        {
            ECommerceOMS.Models.OrderStatus.Delivered  => "bg-success",
            ECommerceOMS.Models.OrderStatus.Cancelled  => "bg-danger",
            ECommerceOMS.Models.OrderStatus.Shipped    => "bg-info",
            ECommerceOMS.Models.OrderStatus.Processing => "bg-primary",
            _                                          => "bg-warning text-dark"
        };
    }
}

<div class="row">
    <div class="col-md-4">
        <div class="card shadow mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-person-circle"></i> Customer Profile</h5>
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr>
                        <td class="fw-bold">Name:</td>
                        <td>@Model.FullName</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Email:</td>
                        <td>@Model.Email</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Phone:</td>
                        <td>@Model.Phone</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Address:</td>
                        <td>@Model.Address</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Joined:</td>
                        <td>@Model.CreatedAt.ToString("dd MMM yyyy")</td>
                    </tr>
                </table>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <a asp-action="Index" class="btn btn-secondary btn-sm">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">
                    <i class="bi bi-clock-history"></i> Order History
                    <span class="badge bg-warning text-dark ms-2">@Model.Orders.Count orders</span>
                </h5>
            </div>
            <div class="card-body p-0">
                @if (!Model.Orders.Any())
                {
                    <div class="p-3 text-muted">
                        <i class="bi bi-inbox"></i> No orders placed yet.
                    </div>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-secondary">
                            <tr>
                                <th>Order#</th>
                                <th>Date</th>
                                <th>Items</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th>Shipping</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.Orders.OrderByDescending(o => o.OrderDate))
                            {
                                <tr>
                                    <td>#@order.Id</td>
                                    <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                                    <td>@order.OrderItems.Count</td>
                                    <td class="fw-bold text-success">₹@order.TotalAmount.ToString("N2")</td>
                                    <td>
                                        <span class="badge @GetStatusBadge(order.Status)">
                                            @order.Status
                                        </span>
                                    </td>
                                    <td>
                                        @if (order.ShippingDetail != null)
                                        {
                                            <span class="badge bg-secondary">
                                                @order.ShippingDetail.Status
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-controller="Orders" asp-action="Details"
                                           asp-route-id="@order.Id"
                                           class="btn btn-sm btn-info text-white">
                                            View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>