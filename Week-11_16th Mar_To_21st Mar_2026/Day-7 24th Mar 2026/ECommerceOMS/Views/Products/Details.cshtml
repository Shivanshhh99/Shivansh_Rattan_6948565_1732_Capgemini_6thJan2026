@model ECommerceOMS.Models.Product
@{ ViewData["Title"] = "Product Details"; }

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-box-seam"></i> Product Details</h5>
                <span class="badge bg-warning text-dark">@Model.Category?.Name</span>
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <td class="fw-bold" style="width:140px">Product Name:</td>
                        <td>@Model.Name</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Description:</td>
                        <td>@Model.Description</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Price:</td>
                        <td class="text-success fw-bold fs-5">₹@Model.Price.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Stock:</td>
                        <td>
                            <span class="badge @(Model.StockQuantity > 0 ? "bg-success" : "bg-danger") fs-6">
                                @Model.StockQuantity units
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Category:</td>
                        <td>@Model.Category?.Name</td>
                    </tr>
                </table>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Delete
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>
        </div>
    </div>
</div>