@model ECommerceOMS.ViewModels.ProductFilterViewModel
@{ ViewData["Title"] = "Products"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam"></i> Products</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Add Product
    </a>
</div>

<!-- Filter Bar -->
<form method="get" class="card card-body mb-4 bg-light">
    <div class="row g-3">
        <div class="col-md-5">
            <input type="text" name="search" value="@Model.SearchTerm"
                   placeholder="Search products..." class="form-control" />
        </div>
        <div class="col-md-4">
            <select name="categoryId" class="form-select">
                <option value="">All Categories</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat.Id" selected="@(Model.SelectedCategoryId == cat.Id)">@cat.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-funnel"></i> Filter
            </button>
        </div>
    </div>
</form>

<!-- Product Cards -->
<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var p in Model.Products)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <span class="badge bg-warning text-dark">@p.Category?.Name</span>
                </div>
                <div class="card-body">
                    <h5 class="card-title">@p.Name</h5>
                    <p class="card-text text-muted small">@p.Description</p>
                    <div class="d-flex justify-content-between">
                        <span class="fs-5 fw-bold text-success">₹@p.Price.ToString("N2")</span>
                        <span class="badge @(p.StockQuantity > 0 ? "bg-success" : "bg-danger")">
                            Stock: @p.StockQuantity
                        </span>
                    </div>
                </div>
                <div class="card-footer d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-info text-white">
                        <i class="bi bi-eye"></i> View
                    </a>
                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-warning">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-danger">
                        <i class="bi bi-trash"></i> Delete
                    </a>
                </div>
            </div>
        </div>
    }
</div>
@if (!Model.Products.Any())
{
    <div class="alert alert-info mt-3">No products found.</div>
}