@model IEnumerable<ECommerceOMS.Models.Order>
@{
    ViewData["Title"] = "Orders";

    string GetStatusBadge(ECommerceOMS.Models.OrderStatus status)
    {
        return status switch
        {
            ECommerceOMS.Models.OrderStatus.Delivered  => "bg-success",
            ECommerceOMS.Models.OrderStatus.Cancelled  => "bg-danger",
            ECommerceOMS.Models.OrderStatus.Shipped    => "bg-info",
            ECommerceOMS.Models.OrderStatus.Processing => "bg-primary",
            _                                          => "bg-warning text-dark"
        };
    }
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-cart3"></i> Orders</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-cart-plus"></i> Place New Order
    </a>
</div>

<div class="card shadow">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Order #</th>
                    <th>Customer</th>
                    <th>Order Date</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Shipping</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td><strong>#@order.Id</strong></td>
                        <td>@order.Customer?.FullName</td>
                        <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                        <td class="fw-bold text-success">₹@order.TotalAmount.ToString("N2")</td>
                        <td>
                            <span class="badge @GetStatusBadge(order.Status)">
                                @order.Status
                            </span>
                        </td>
                        <td>
                            @if (order.ShippingDetail != null)
                            {
                                <span class="badge bg-secondary">@order.ShippingDetail.Status</span>
                            }
                            else
                            {
                                <span class="text-muted small">N/A</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@order.Id"
                               class="btn btn-sm btn-info text-white">
                                <i class="bi bi-eye"></i> View
                            </a>
                            <a asp-action="Delete" asp-route-id="@order.Id"
                               class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">
        <i class="bi bi-info-circle"></i> No orders found.
    </div>
}