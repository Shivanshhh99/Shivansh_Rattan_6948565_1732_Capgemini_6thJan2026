@model ECommerceOMS.ViewModels.OrderDetailViewModel
@{ ViewData["Title"] = "Order #" + Model.OrderId; }

<div class="row">
    <div class="col-md-8">
        <div class="card shadow mb-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between">
                <h5 class="mb-0"><i class="bi bi-receipt"></i> Order #@Model.OrderId</h5>
                <span class="badge bg-warning text-dark fs-6">@Model.Status</span>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <strong>Customer:</strong> @Model.CustomerName <br />
                        <strong>Email:</strong> @Model.CustomerEmail <br />
                        <strong>Order Date:</strong> @Model.OrderDate.ToString("dd MMM yyyy, hh:mm tt")
                    </div>
                    <div class="col-md-6 text-md-end">
                        <h4 class="text-success">Total: ₹@Model.TotalAmount.ToString("N2")</h4>
                    </div>
                </div>

                <h6 class="border-bottom pb-2">Order Items</h6>
                <table class="table table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th>Product</th>
                            <th>Qty</th>
                            <th>Unit Price</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.Quantity</td>
                                <td>₹@item.UnitPrice.ToString("N2")</td>
                                <td>₹@item.Subtotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-truck"></i> Shipping Details</h5>
            </div>
            <div class="card-body">
                <p><strong>Address:</strong><br />@Model.ShippingAddress</p>
                <p><strong>Carrier:</strong> @(string.IsNullOrEmpty(Model.CarrierName) ? "Not assigned" : Model.CarrierName)</p>
                <p><strong>Tracking #:</strong> @(string.IsNullOrEmpty(Model.TrackingNumber) ? "N/A" : Model.TrackingNumber)</p>
                <p><strong>Est. Delivery:</strong> @(Model.EstimatedDelivery?.ToString("dd MMM yyyy") ?? "TBD")</p>
                <div class="mt-2">
                    <span class="badge bg-primary fs-6">@Model.ShippingStatus</span>
                </div>
            </div>
        </div>
        <a asp-action="Index" class="btn btn-secondary mt-3 w-100">
            <i class="bi bi-arrow-left"></i> Back to Orders
        </a>
    </div>
</div>