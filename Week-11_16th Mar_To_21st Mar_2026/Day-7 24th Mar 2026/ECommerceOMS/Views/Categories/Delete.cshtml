@model ECommerceOMS.Models.Category
@{ ViewData["Title"] = "Delete Category"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Delete Category</h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <strong>Warning!</strong> Deleting this category may affect products assigned to it.
                </div>
                <table class="table table-borderless">
                    <tr><td class="fw-bold">Name:</td><td>@Model.Name</td></tr>
                    <tr><td class="fw-bold">Description:</td><td>@Model.Description</td></tr>
                </table>
                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Yes, Delete
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>