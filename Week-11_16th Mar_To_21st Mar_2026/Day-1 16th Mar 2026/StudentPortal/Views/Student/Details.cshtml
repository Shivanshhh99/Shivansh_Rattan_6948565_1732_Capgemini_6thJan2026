@model StudentPortal.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">
    <div class="card shadow-lg p-4 rounded-4 text-center">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        <h2 class="text-success mb-4">Registration Successful 🎉</h2>

        <h4><strong>Student ID:</strong> @Model.Id</h4>
        <h4><strong>Name:</strong> @Model.Name</h4>
        <h4><strong>Age:</strong> @Model.Age</h4>

        <a asp-action="Register" class="btn btn-outline-primary mt-4">
            Register Another Student
        </a>
        <a asp-action="List" class="btn btn-success mt-3">
            View All Students
        </a>
    </div>
</div>
