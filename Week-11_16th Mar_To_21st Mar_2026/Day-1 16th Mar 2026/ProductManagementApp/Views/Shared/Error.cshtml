@{
    ViewData["Title"] = "Error";
    var message = ViewData["ErrorMessage"] as string ?? "Something went wrong!";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">
    <div class="d-flex justify-content-center">

        <div class="card shadow-lg p-5 text-center" style="max-width: 600px; width: 100%;">

            <div class="mb-4">
                <h1 class="text-danger">⚠️ Oops!</h1>
                <h4 class="text-dark">An error occurred</h4>
            </div>

            <p class="text-muted fs-5">
                @message
            </p>

            <div class="mt-4">
                <a href="/Product/Index" class="btn btn-primary px-4">
                    Go Back to Products
                </a>
            </div>

        </div>

    </div>
</div>