@model StudentManagementSystem.Models.Product
@{
    ViewData["Title"] = "Create Product";
}

<div class="page-header">
    <h1 class="page-title">Create Product</h1>
    <p class="page-subtitle">Add a new product to the catalog.</p>
</div>

<div class="card" style="max-width:700px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="form-grid">
            <div class="form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" placeholder="Product name" />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Price"></label>
                <input asp-for="Price" type="number" step="0.01" placeholder="0.00" />
                <span asp-validation-for="Price" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Category"></label>
                <select asp-for="Category">
                    <option value="">-- Select Category --</option>
                    <option value="Electronics">Electronics</option>
                    <option value="Furniture">Furniture</option>
                    <option value="Stationery">Stationery</option>
                    <option value="Software">Software</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="form-group full-width">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" rows="3" placeholder="Short product description"></textarea>
                <span asp-validation-for="Description" class="field-validation-error"></span>
            </div>
        </div>
        <div style="display:flex;gap:0.75rem;margin-top:1.75rem;">
            <button type="submit" class="btn btn-primary">Create Product →</button>
            <a href="/Product/Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>