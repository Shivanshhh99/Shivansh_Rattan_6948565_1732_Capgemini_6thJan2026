@{
    ViewData["Title"] = "Error";
    var errMsg = ViewData["ErrorMessage"]?.ToString() ?? "An unexpected error occurred.";
}

<div style="max-width:600px;margin:3rem auto;">
    <div class="card" style="border-color:rgba(247,106,106,0.25);text-align:center;padding:3rem;">
        <div style="font-size:4rem;margin-bottom:1rem;">⚠</div>
        <h1 style="font-family:'Syne',sans-serif;font-size:1.5rem;color:var(--error);margin-bottom:0.75rem;">
            Something Went Wrong
        </h1>
        <p style="color:var(--text-secondary);margin-bottom:1.5rem;">
            The error has been caught by the global exception filter.
        </p>
        <div style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-sm);padding:1rem;text-align:left;font-size:0.85rem;color:var(--error);margin-bottom:1.5rem;font-family:monospace;">
            @errMsg
        </div>
        <a href="/Account/Dashboard" class="btn btn-primary">← Return to Dashboard</a>
    </div>
</div>