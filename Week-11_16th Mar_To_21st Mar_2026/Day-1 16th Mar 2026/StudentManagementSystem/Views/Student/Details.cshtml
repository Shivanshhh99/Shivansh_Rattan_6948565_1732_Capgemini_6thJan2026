@model StudentManagementSystem.Models.Student
@{
    ViewData["Title"] = "Student Details";
}

<div class="page-header">
    <div style="display:flex;align-items:center;justify-content:space-between;">
        <div>
            <h1 class="page-title">Student Profile</h1>
            <p class="page-subtitle">Registration confirmed · ID #@Model.Id</p>
        </div>
        <span class="badge badge-green">✓ Registered</span>
    </div>
</div>

<div class="card" style="max-width:700px;">
    <div style="display:flex;align-items:center;gap:1.5rem;margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:1px solid var(--border);">
        <div style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent-2));display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;color:white;flex-shrink:0;">
            @Model.Name[0].ToString().ToUpper()
        </div>
        <div>
            <h2 style="font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:700;">@Model.Name</h2>
            <p style="color:var(--text-secondary);font-size:0.875rem;">@Model.Course</p>
        </div>
    </div>

    <div class="details-grid">
        <div class="detail-item">
            <div class="detail-label">Student ID</div>
            <div class="detail-value">#@Model.Id.ToString("D4")</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Age</div>
            <div class="detail-value">@Model.Age years</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Email Address</div>
            <div class="detail-value">@Model.Email</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Enrolled Course</div>
            <div class="detail-value"><span class="badge badge-purple">@Model.Course</span></div>
        </div>
        <div class="detail-item" style="grid-column:1/-1;">
            <div class="detail-label">Registered On</div>
            <div class="detail-value">@Model.RegisteredOn.ToString("dddd, MMMM dd yyyy · HH:mm")</div>
        </div>
    </div>

    <div style="display:flex;gap:0.75rem;margin-top:1.75rem;">
        <a href="/Student/Register" class="btn btn-primary">+ Register Another</a>
        <a href="/Student/List" class="btn btn-secondary">View All Students</a>
        <a href="/Account/Dashboard" class="btn btn-secondary">Dashboard</a>
    </div>
</div>