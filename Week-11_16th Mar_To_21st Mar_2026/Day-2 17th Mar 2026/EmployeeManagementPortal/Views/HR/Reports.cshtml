@{
    ViewData["Title"] = "HR Reports";
    var deptGroups = ViewBag.DeptGroups as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    int total = ViewBag.TotalEmployees ?? 1;
}

<div class="ph">
    <div class="ph-left">
        <h1>HR Reports</h1>
        <p>Analytics and workforce statistics · Exception filter active on this page.</p>
    </div>
    <a href="/HR/Index" class="btn btn-ghost">← HR Overview</a>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.25rem;">

    <!-- Dept Report -->
    <div class="card">
        <div class="card-title">Department Report</div>
        <div class="card-sub">Headcount, average age, active vs inactive</div>
        <hr class="card-divider" />
        <div class="table-wrap" style="border:none;">
            <table>
                <thead>
                    <tr>
                        <th>Department</th>
                        <th>Count</th>
                        <th>Avg Age</th>
                        <th>Active</th>
                        <th>Inactive</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in deptGroups)
                    {
                        <tr>
                            <td><span class="badge badge-teal">@d.Department</span></td>
                            <td style="font-weight:600;">@d.Count</td>
                            <td>@(((double)d.AvgAge).ToString("F1"))</td>
                            <td><span class="badge badge-green">@d.Active</span></td>
                            <td><span class="badge badge-red">@d.Inactive</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Summary -->
    <div style="display:flex;flex-direction:column;gap:1rem;">
        <div class="card card-sm">
            <div class="card-sub" style="margin-bottom:0.25rem;">Oldest Employee</div>
            <div style="font-weight:600;">@(ViewBag.OldestEmployee?.Name ?? "—")</div>
            <div style="font-size:0.8rem;color:var(--text-2);">Age: @(ViewBag.OldestEmployee?.Age ?? "—") · @(ViewBag.OldestEmployee?.Department ?? "")</div>
        </div>
        <div class="card card-sm">
            <div class="card-sub" style="margin-bottom:0.25rem;">Most Recent Join</div>
            <div style="font-weight:600;">@(ViewBag.NewestJoin?.Name ?? "—")</div>
            <div style="font-size:0.8rem;color:var(--text-2);">Joined: @(ViewBag.NewestJoin?.JoinedOn.ToString("MMM dd, yyyy") ?? "—")</div>
        </div>
        <div class="card card-sm" style="background:var(--teal-dim);border-color:rgba(45,212,191,0.2);">
            <div class="card-sub" style="margin-bottom:0.25rem;">Total Registered</div>
            <div style="font-family:'Space Grotesk',sans-serif;font-size:2rem;font-weight:700;color:var(--teal);">@total</div>
            <div style="font-size:0.775rem;color:var(--text-2);">Across all departments</div>
        </div>
    </div>

</div>

<!-- Dept Bars -->
<div class="card">
    <div class="card-title">Distribution Overview</div>
    <div class="card-sub">Visual headcount breakdown by department</div>
    <hr class="card-divider" />
    <div style="display:flex;flex-direction:column;gap:0.85rem;">
        @foreach (var d in deptGroups)
        {
            var pct = (int)((double)d.Count / (double)total * 100);
            <div class="report-row" style="margin-bottom:0;">
                <div class="report-meta">
                    <span class="report-dept">@d.Department</span>
                    <span class="report-count">@d.Count / @total employees (@pct%)</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" style="width:@pct%"></div>
                </div>
            </div>
        }
    </div>
</div>