@model List<EmployeeManagementPortal.Models.Employee>
@{
    ViewData["Title"] = "Employee List";
}

<div class="ph">
    <div class="ph-left">
        <h1>Employee List</h1>
        <p>@Model.Count total employee(s) · Logged by LogActionFilter</p>
    </div>
    <a href="/Employee/Register" class="btn btn-primary">+ Register Employee</a>
</div>

@if (Model.Count == 0)
{
    <div class="card" style="text-align:center;padding:3rem;">
        <p style="color:var(--text-2);">No employees registered yet.</p>
        <a href="/Employee/Register" class="btn btn-primary" style="margin-top:1rem;">Register First Employee</a>
    </div>
}
else
{
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Employee</th>
                    <th>Age</th>
                    <th>Department</th>
                    <th>Job Title</th>
                    <th>Status</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model)
                {
                    <tr>
                        <td><span class="badge badge-teal">#@emp.Id.ToString("D4")</span></td>
                        <td>
                            <div class="employee-cell">
                                <div class="avatar">@emp.Name[0].ToString().ToUpper()</div>
                                <div>
                                    <div class="employee-name">@emp.Name</div>
                                    <div class="employee-email">@emp.Email</div>
                                </div>
                            </div>
                        </td>
                        <td>@emp.Age</td>
                        <td><span class="badge badge-amber">@emp.Department</span></td>
                        <td style="color:var(--text-2);">@(string.IsNullOrEmpty(emp.JobTitle) ? "—" : emp.JobTitle)</td>
                        <td>
                            @if (emp.Status == "Active")
                            {
                                <span class="badge badge-green">Active</span>
                            }
                            else
                            {

                                <span class="badge badge-red">@emp.Status</span>
                            }
                        </td>
                        <td style="color:var(--text-2);font-size:0.8rem;">@emp.JoinedOn.ToString("MMM dd, yyyy")</td>
                        <td><a href="/Employee/Details/@emp.Id" class="btn btn-ghost btn-sm">View →</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}