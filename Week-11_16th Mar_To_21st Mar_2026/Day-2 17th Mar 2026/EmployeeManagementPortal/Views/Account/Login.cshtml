@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login — EMP Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="login-page">

        <!-- LEFT PANEL -->
        <div class="login-left">
            <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:3rem;">
                <div class="brand-mark">E</div>
                <div>
                    <div class="brand-name">EMP Portal</div>
                    <div class="brand-sub">Employee Management System</div>
                </div>
            </div>

            <h1 class="login-tagline">
                Manage your<br><span>workforce</span><br>with confidence.
            </h1>
            <p class="login-desc">
                A centralized portal for HR teams to register, track,
                and manage employee data with full audit logging.
            </p>

            <div class="feature-list">
                <div class="feature-item"><span class="feature-check">✓</span> Employee Registration & Profiles</div>
                <div class="feature-item"><span class="feature-check">✓</span> HR Analytics & Reports</div>
                <div class="feature-item"><span class="feature-check">✓</span> Action Logging on Every Request</div>
                <div class="feature-item"><span class="feature-check">✓</span> Secure Session-Based Authentication</div>
            </div>
        </div>

        <!-- RIGHT PANEL -->
        <div class="login-right">
            <div class="login-box">
                <h2 class="login-box-title">Admin Sign In</h2>
                <p class="login-box-sub">Enter your credentials to access the portal.</p>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="toast toast-success" style="margin-bottom:1rem;">
                        <span>✓</span> @TempData["SuccessMessage"]
                    </div>
                }

                @if (ViewBag.Error != null)
                {
                    <div class="error-banner">⚠ @ViewBag.Error</div>
                }

                <form class="login-form" method="post" action="/Account/Login">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label for="username">Username</label>
                        <input type="text" id="username" name="username"
                               placeholder="admin" required autocomplete="username" />
                    </div>
                    <div class="form-group">
                        <label for="password">Password</label>
                        <input type="password" id="password" name="password"
                               placeholder="••••••••" required autocomplete="current-password" />
                    </div>
                    <button type="submit" class="btn btn-primary" style="width:100%;padding:0.75rem;">
                        Sign In →
                    </button>
                </form>

                <div class="credentials-hint">
                    Demo: <strong>admin</strong> / <strong>admin123</strong>
                </div>
            </div>
        </div>

    </div>
</body>
</html>