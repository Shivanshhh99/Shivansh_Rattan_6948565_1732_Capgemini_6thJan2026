@model EmployeeManagementPortal.Models.Employee
@{
    ViewData["Title"] = "Register Employee";
}

<div class="ph">
    <div class="ph-left">
        <h1>Register Employee</h1>
        <p>Fill in the details below to add a new employee record.</p>
    </div>
    <a href="/Account/Dashboard" class="btn btn-ghost">← Dashboard</a>
</div>

<div class="card" style="max-width:720px;">
    <div class="card-title">Employee Details</div>
    <div class="card-sub">All fields marked with * are required.</div>
    <hr class="card-divider" />

    <form asp-action="Register" method="post">
        @Html.AntiForgeryToken()
        <div class="form-grid">

            <div class="form-group">
                <label asp-for="Name">Full Name *</label>
                <input asp-for="Name" placeholder="e.g. Priya Sharma" />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Age">Age *</label>
                <input asp-for="Age" type="number" placeholder="21–65" min="21" max="65" />
                <span asp-validation-for="Age" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email">Email Address *</label>
                <input asp-for="Email" type="email" placeholder="name@company.com" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Department">Department *</label>
                <select asp-for="Department">
                    <option value="">-- Select Department --</option>
                    <option value="Engineering">Engineering</option>
                    <option value="HR">Human Resources</option>
                    <option value="Finance">Finance</option>
                    <option value="Operations">Operations</option>
                    <option value="Marketing">Marketing</option>
                    <option value="Sales">Sales</option>
                    <option value="Legal">Legal</option>
                    <option value="IT">IT</option>
                </select>
                <span asp-validation-for="Department" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="JobTitle">Job Title</label>
                <input asp-for="JobTitle" placeholder="e.g. Software Engineer" />
            </div>

            <div class="form-group">
                <label asp-for="Status">Status</label>
                <select asp-for="Status">
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                    <option value="On Leave">On Leave</option>
                </select>
            </div>

        </div>

        <div class="form-actions" style="margin-top:1.5rem;">
            <button type="submit" class="btn btn-primary">Register Employee →</button>
            <a href="/Account/Dashboard" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>